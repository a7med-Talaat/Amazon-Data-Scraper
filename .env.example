# Copy this file to .env and adjust as needed (then `export $(cat .env | xargs)`
# or use a tool like python-dotenv / direnv to load it automatically).

# Random delay range between requests, in seconds
SCRAPER_MIN_DELAY=3
SCRAPER_MAX_DELAY=7

# Retry policy
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_FACTOR=2
SCRAPER_TIMEOUT=10

# Optional proxy, e.g. http://user:pass@host:port
# Amazon scraping at any real scale generally requires residential proxies.
SCRAPER_PROXY=

# Storage paths
SCRAPER_DB_PATH=output/amazon_data.db
SCRAPER_CSV_SEARCH=output/search_results.csv
SCRAPER_CSV_PRODUCTS=output/products.csv
SCRAPER_REPORT_DIR=output/report
